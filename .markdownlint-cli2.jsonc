{
  "config": {
    "default": true,
    "MD013": false,
    "MD033": false,
    "MD041": false,
    "MD060": false
  },
  "globs": ["**/*.md"],
  "ignores": [
    "**/node_modules/**",
    "dist/**",
    ".check/**",
    ".stryker-tmp/**",
    "docs/**",
    ".ridgeline/**",
    "research/**",
    "spec/**",
    "examples/**/.runs/**",
    "CHANGELOG.md"
  ]
}
