{
  "compilerOptions": {
    "target": "ES2024",
    "lib": ["ES2024"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",

    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "noImplicitOverride": true,
    "noPropertyAccessFromIndexSignature": true,
    "noFallthroughCasesInSwitch": true,

    "isolatedModules": true,
    "verbatimModuleSyntax": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "types": ["node"],

    "noEmit": true,

    "paths": {
      "fascicle": ["./src/index.ts"],
      "fascicle/adapters": ["./src/adapters/index.ts"],
      "fascicle/mcp": ["./src/mcp/index.ts"],
      "fascicle/stdio": ["./src/stdio/index.ts"],
      "fascicle/agents": ["./src/agents/index.ts"],
      "#core": ["./src/core/index.ts"],
      "#engine": ["./src/engine/index.ts"],
      "#composites": ["./src/composites/index.ts"],
      "#adapters": ["./src/adapters/index.ts"],
      "#viewer": ["./src/viewer/index.ts"],
      "#agents": ["./src/agents/index.ts"],
      "#stdio": ["./src/stdio/index.ts"]
    }
  },
  "include": [
    "src/**/*",
    "examples/**/*.ts",
    "test/**/*.ts"
  ],
  "exclude": ["node_modules", "**/dist", ".check"]
}
