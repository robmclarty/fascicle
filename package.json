{
  "name": "fascicle",
  "version": "0.8.9",
  "description": "Compose agents like plain values. A TypeScript toolkit that wires LLM calls, tools, and functions into typed steps over eight providers. No framework, no ambient state.",
  "keywords": [
    "agents",
    "agentic",
    "multi-agent",
    "ai",
    "llm",
    "workflow",
    "pipeline",
    "orchestration",
    "tool-calling",
    "harness",
    "streaming",
    "observability",
    "typescript",
    "composable",
    "ai-sdk",
    "vercel-ai-sdk",
    "anthropic",
    "openai",
    "gemini",
    "bedrock",
    "openrouter",
    "ollama",
    "lmstudio"
  ],
  "license": "Apache-2.0",
  "author": {
    "name": "Rob McLarty",
    "email": "hello@robmclarty.com",
    "url": "https://robmclarty.com"
  },
  "type": "module",
  "engines": {
    "node": ">=24.0.0",
    "pnpm": ">=10.13.0"
  },
  "packageManager": "pnpm@11.1.2",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./adapters": {
      "types": "./dist/adapters.d.ts",
      "import": "./dist/adapters.js"
    },
    "./mcp": {
      "types": "./dist/mcp.d.ts",
      "import": "./dist/mcp.js"
    }
  },
  "imports": {
    "#core": "./src/core/index.ts",
    "#engine": "./src/engine/index.ts",
    "#composites": "./src/composites/index.ts",
    "#adapters": "./src/adapters/index.ts",
    "#viewer": "./src/viewer/index.ts",
    "#agents": "./src/agents/index.ts"
  },
  "bin": {
    "fascicle-viewer": "./dist/bin/fascicle-viewer.js"
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/robmclarty/fascicle.git"
  },
  "homepage": "https://robmclarty.github.io/fascicle/",
  "bugs": {
    "url": "https://github.com/robmclarty/fascicle/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "node scripts/build.mjs",
    "check": "node scripts/check.mjs",
    "check:all": "node scripts/check.mjs --all",
    "check:json": "node scripts/check.mjs --json",
    "check:bail": "node scripts/check.mjs --bail",
    "check:fix": "pnpm exec oxlint --type-aware --fix && node scripts/strip-semicolons.mjs && pnpm exec fallow fix",
    "check:mutation": "stryker run",
    "check:publish": "node scripts/check-publish.mjs",
    "check:security": "pnpm audit --audit-level=high",
    "prepublishOnly": "pnpm check && pnpm build && pnpm check:publish",
    "test": "vitest run",
    "test:watch": "vitest",
    "types": "tsc --noEmit",
    "fascicle-viewer": "tsx src/viewer/cli.ts"
  },
  "peerDependencies": {
    "@ai-sdk/amazon-bedrock": "^3.0.0",
    "@ai-sdk/anthropic": "^3.0.0",
    "@ai-sdk/google": "^3.0.0",
    "@ai-sdk/openai": "^3.0.0",
    "@ai-sdk/openai-compatible": "^2.0.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@openrouter/ai-sdk-provider": "^2.0.0",
    "ai": "^6.0.0",
    "ai-sdk-ollama": "^3.0.0",
    "zod": "^4.0.0"
  },
  "peerDependenciesMeta": {
    "@ai-sdk/amazon-bedrock": {
      "optional": true
    },
    "@ai-sdk/anthropic": {
      "optional": true
    },
    "@ai-sdk/google": {
      "optional": true
    },
    "@ai-sdk/openai": {
      "optional": true
    },
    "@ai-sdk/openai-compatible": {
      "optional": true
    },
    "@modelcontextprotocol/sdk": {
      "optional": true
    },
    "@openrouter/ai-sdk-provider": {
      "optional": true
    },
    "ai-sdk-ollama": {
      "optional": true
    }
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "0.18.2",
    "@ast-grep/cli": "0.42.1",
    "@modelcontextprotocol/sdk": "1.29.0",
    "@stryker-mutator/core": "9.6.1",
    "@stryker-mutator/vitest-runner": "9.6.1",
    "@types/node": "24.12.2",
    "@vitest/coverage-v8": "4.1.4",
    "cspell": "10.0.0",
    "fallow": "2.40.3",
    "markdownlint-cli2": "0.22.0",
    "oxlint": "1.60.0",
    "oxlint-tsgolint": "0.21.1",
    "tsdown": "0.21.9",
    "tsx": "4.21.0",
    "typescript": "6.0.3",
    "vitest": "4.1.4",
    "zod": "4.3.6"
  }
}
