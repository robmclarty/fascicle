{
  "name": "fascicle",
  "version": "0.9.2",
  "description": "Compose agents like plain values. A TypeScript toolkit that wires LLM calls, tools, and functions into typed steps over eight providers. No framework, no ambient state.",
  "keywords": [
    "agents",
    "agentic",
    "multi-agent",
    "ai",
    "llm",
    "workflow",
    "pipeline",
    "orchestration",
    "tool-calling",
    "harness",
    "streaming",
    "observability",
    "typescript",
    "composable",
    "ai-sdk",
    "vercel-ai-sdk",
    "anthropic",
    "openai",
    "gemini",
    "bedrock",
    "openrouter",
    "ollama",
    "lmstudio"
  ],
  "license": "Apache-2.0",
  "author": {
    "name": "Rob McLarty",
    "email": "hello@robmclarty.com",
    "url": "https://robmclarty.com"
  },
  "type": "module",
  "engines": {
    "node": ">=24.0.0",
    "pnpm": ">=10.13.0"
  },
  "packageManager": "pnpm@11.1.2",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./adapters": {
      "types": "./dist/adapters.d.ts",
      "import": "./dist/adapters.js"
    },
    "./mcp": {
      "types": "./dist/mcp.d.ts",
      "import": "./dist/mcp.js"
    },
    "./otel": {
      "types": "./dist/otel.d.ts",
      "import": "./dist/otel.js"
    },
    "./stdio": {
      "types": "./dist/stdio.d.ts",
      "import": "./dist/stdio.js"
    },
    "./ui": {
      "types": "./dist/ui.d.ts",
      "import": "./dist/ui.js"
    }
  },
  "imports": {
    "#core": "./src/core/index.ts",
    "#engine": "./src/engine/index.ts",
    "#composites": "./src/composites/index.ts",
    "#adapters": "./src/adapters/index.ts",
    "#viewer": "./src/viewer/index.ts",
    "#agents": "./src/agents/index.ts",
    "#stdio": "./src/stdio/index.ts",
    "#ui": "./src/ui/index.ts"
  },
  "bin": {
    "fascicle-viewer": "./dist/bin/fascicle-viewer.js"
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/robmclarty/fascicle.git"
  },
  "homepage": "https://robmclarty.github.io/fascicle/",
  "bugs": {
    "url": "https://github.com/robmclarty/fascicle/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "node scripts/build.mjs",
    "check": "node scripts/check.mjs",
    "check:all": "node scripts/check.mjs --all",
    "check:json": "node scripts/check.mjs --json",
    "check:bail": "node scripts/check.mjs --bail",
    "check:fix": "pnpm exec oxlint --type-aware --fix && node scripts/strip-semicolons.mjs && pnpm exec fallow fix",
    "check:mutation": "stryker run",
    "check:publish": "node scripts/check-publish.mjs",
    "check:security": "pnpm audit --audit-level=high",
    "prepublishOnly": "pnpm check && pnpm build && pnpm check:publish",
    "test": "vitest run",
    "test:watch": "vitest",
    "types": "tsc --noEmit",
    "fascicle-viewer": "tsx src/viewer/cli.ts"
  },
  "peerDependencies": {
    "@ai-sdk/amazon-bedrock": "^5.0.0",
    "@ai-sdk/anthropic": "^4.0.0",
    "@ai-sdk/google": "^4.0.0",
    "@ai-sdk/openai": "^4.0.0",
    "@ai-sdk/openai-compatible": "^3.0.0",
    "@ai-sdk/otel": "^1.0.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@openrouter/ai-sdk-provider": "^3.0.0",
    "@opentelemetry/api": "^1.9.0",
    "ai": "^7.0.0",
    "ai-sdk-ollama": "^4.0.0",
    "zod": "^4.0.0"
  },
  "peerDependenciesMeta": {
    "@ai-sdk/amazon-bedrock": {
      "optional": true
    },
    "@ai-sdk/anthropic": {
      "optional": true
    },
    "@ai-sdk/google": {
      "optional": true
    },
    "@ai-sdk/openai": {
      "optional": true
    },
    "@ai-sdk/openai-compatible": {
      "optional": true
    },
    "@ai-sdk/otel": {
      "optional": true
    },
    "@modelcontextprotocol/sdk": {
      "optional": true
    },
    "@openrouter/ai-sdk-provider": {
      "optional": true
    },
    "@opentelemetry/api": {
      "optional": true
    },
    "ai-sdk-ollama": {
      "optional": true
    }
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "0.18.4",
    "@ast-grep/cli": "0.44.1",
    "@modelcontextprotocol/sdk": "1.29.0",
    "@opentelemetry/sdk-trace-base": "2.9.0",
    "@stryker-mutator/core": "9.6.1",
    "@stryker-mutator/vitest-runner": "9.6.1",
    "@types/node": "26.1.0",
    "@vitest/coverage-v8": "4.1.10",
    "cspell": "10.0.1",
    "fallow": "3.2.0",
    "markdownlint-cli2": "0.23.0",
    "oxlint": "1.73.0",
    "oxlint-tsgolint": "0.24.0",
    "tsdown": "0.22.3",
    "tsx": "4.23.0",
    "typescript": "6.0.3",
    "vitest": "4.1.10",
    "zod": "4.4.3"
  }
}
