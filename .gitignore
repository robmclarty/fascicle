node_modules/
/dist
.check/
.fallow/
.stryker-tmp/
stryker.incremental.json
coverage/
*.log
.DS_Store
.claude/settings.local.json
.claude/scheduled_tasks.lock
.pnpm-store/
tsconfig.tsbuildinfo
.env

# ridgeline build runtime artifacts (specs, taste, constraints, handoff, phases markdown stay tracked)
.ridgeline/builds/*/state.json
.ridgeline/builds/*/budget.json
.ridgeline/builds/*/*.jsonl

# rgr example trajectory output
examples/red-green-refactor/.trajectory/

# pr-improve worktrees, created in the host repo when pr-improve runs
# against a real PR. (Per-run artifacts under examples/pr-improve/.runs/
# are ignored by examples/pr-improve/.gitignore.)
.fascicle/

# playwright MCP scratch (browser snapshots/logs from interactive testing)
.playwright-mcp/

# working research notes, specs, and explorations (root only; the design
# rationale bundled with examples/amplify/research/ stays tracked)
/research/

# plumbbob build artifacts (intents, build logs, reports); they absorb the
# research notes above, so they stay local for the same reason
/.plumbbob/
